    "deny": [
      "Read(~/.aws/**)",
      "Read(~/.bash_secrets)",
      "Read(~/secret/*)",
      "Read(~/.config/gh/**)",
      "Read(~/.docker/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.ssh/**)"
